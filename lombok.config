## DGG Spring Boot 项目 Lombok 配置
# - config.stopBubbling = true：仅在项目根目录读取 lombok.config，不向上冒泡查找
# - lombok.copyableAnnotations：让 @RequiredArgsConstructor 把指定注解从字段复制到生成的构造器参数上
#   关键作用：使 @Value 与 @RequiredArgsConstructor 共存时，@Value 能正确传递到构造器参数，
#   从而让 Spring 完成属性注入（否则 Spring 无法为一个裸 String 构造器参数注入值）。
config.stopBubbling = true
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Value
lombok.copyableAnnotations += org.springframework.boot.context.properties.bind.DefaultValue
