# ============================================================================
# FinHub 环境变量模板
# 使用方式：cp .env.example .env → 填入真实值 → docker compose up
# ⚠️ .env 文件已加入 .gitignore，禁止提交到 Git
# ============================================================================

# ── MySQL 数据库 ──
DB_USERNAME=finhub
DB_PASSWORD=change-me

# ── AES-256 加密密钥（必须恰好 32 字节 UTF-8 原始字符，非 base64） ──
# 生成方式（任选其一）：
#   openssl rand -hex 16            # 生成 32 个十六进制字符（= 32 字节）
#   head -c 32 /dev/urandom | xxd -p | head -c 32
# 注意：EncryptedString.validateKeyLength 强校验 32 字节，否则应用启动失败
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── 排重指纹盐值（任意非空字符串，每实例独立，防止指纹碰撞） ──
FINHUB_FINGERPRINT_SALT=dev-salt-please-override

# ── AI 后端（Claude / OpenAI / Ollama） ──
# 当前活跃的 AI provider：claude | openai | ollama
AI_ACTIVE_PROVIDER=claude

# Claude（Anthropic）
ANTHROPIC_API_KEY=sk-ant-change-me

# OpenAI（可选）
OPENAI_API_KEY=sk-change-me

# Ollama（本地部署，可选）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3

# ── Basic Auth（Spring Security） ──
# 用户名/密码通过环境变量注入，禁止硬编码
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me

# ── Docker Compose 专用 ──
# MySQL root 密码（仅本地 Docker Compose 使用）
MYSQL_ROOT_PASSWORD=change-me
# MySQL 数据卷挂载路径（宿主机）
MYSQL_DATA_DIR=./data/mysql