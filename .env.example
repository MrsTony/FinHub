# ============================================================================
# FinHub 环境变量模板
# 使用方式：cp .env.example .env → 填入真实值 → docker compose up
# ⚠️ .env 文件已加入 .gitignore，禁止提交到 Git
# ============================================================================

# ── MySQL 数据库 ──
DB_USERNAME=finhub
DB_PASSWORD=change-me

# ── AES-256 加密密钥（32 字节） ──
# 生成方式：openssl rand -base64 32
ENCRYPTION_KEY=change-me-to-32-byte-base64-key

# ── 排重指纹盐值 ──
# 每个实例独立，防止指纹碰撞
FINHUB_FINGERPRINT_SALT=change-me

# ── AI 后端（Claude / OpenAI / Ollama） ──
# 当前活跃的 AI provider：claude | openai | ollama
AI_ACTIVE_PROVIDER=claude

# Claude（Anthropic）
ANTHROPIC_API_KEY=sk-ant-change-me

# OpenAI（可选）
OPENAI_API_KEY=sk-change-me

# Ollama（本地部署，可选）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3

# ── Basic Auth（Spring Security） ──
# 用户名/密码通过环境变量注入，禁止硬编码
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me

# ── Docker Compose 专用 ──
# MySQL root 密码（仅本地 Docker Compose 使用）
MYSQL_ROOT_PASSWORD=change-me
# MySQL 数据卷挂载路径（宿主机）
MYSQL_DATA_DIR=./data/mysql